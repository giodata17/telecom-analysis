   "source": [
    "# Limpia separadores y convierte columnas numéricas en eco\n",
    "eco['city_gdp_capita'] = eco['city_gdp_capita'].astype(str).str.replace(',', '.').astype(float)\n",
    "eco['unemployment_percent'] = eco['unemployment_percent'].astype(str).str.replace('%', '').str.replace(',', '.').astype(float)\n",
    "eco['pm_25'] = eco['pm_25'].astype(str).str.replace(',', '.').astype(float)\n",
    "eco['population'] = eco['population'].astype(str).str.replace(',', '.').astype(float)\n",
    "\n",
    "# Calcula la población total en unidades absolutas (Multiplica * 1000000)\n",
    "eco['population'] = eco['population'] * 1000000\n",
    "\n",
    "# verificar el cambio\n",
    "eco.info()\n",
    "eco.head(3)"
   ]
