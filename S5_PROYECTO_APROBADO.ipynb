   "source": [
    "\n",
    "\n",
    "# Seleccionar columnas clave de tráfico y economía\n",
    "left_cols = ['city','country','year','jams_delay','traffic_index_live',\n",
    "'jams_length_in_kms','jams_count','mins_delay']\n",
    "\n",
    "right_cols = ['city','year','country','city_gdp_capita','unemployment_percent','pm_25','population']  \n",
    "\n",
    "# Crear una copia de eco_2024 y cambiar el año a 2024 para el análisis\n",
    "traffic_2024_small = traffic_city_year_2024[left_cols].copy()\n",
    "eco_2024_adjusted = eco_2024.copy()\n",
    "eco_2024_adjusted['year'] = 2024\n",
    "\n",
    "# Ahora hacer el merge\n",
    "merged = pd.merge(traffic_2024_small, eco_2024_adjusted[right_cols],\n",
    "                  on=['city', 'year'],\n",
    "                  how='inner')\n",
    "\n",
    "# Mostrar las primeras 5 filas\n",
    "merged.head()"
   ]
